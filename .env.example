# ─────────────────────────────────────────────────────────────────────────────
# Supabase — accounts + cloud-synced predictions + server-side fixtures cache.
# Create a project at https://supabase.com, then copy these from Project Settings → API.
# The app runs fine without them (on-device/local play); auth + cloud sync stay off.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Deployed site URL — used as the trusted-time source in the native app (where the
# app origin isn't an HTTP server). On the web, same-origin is used automatically.
NEXT_PUBLIC_SITE_URL=

# Cloudflare Turnstile (anti-bot CAPTCHA on sign-in). Optional but recommended.
# Get a site key at https://dash.cloudflare.com → Turnstile, then enable CAPTCHA
# in Supabase → Auth → Attack Protection (paste the secret there) to enforce it.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Global tournament pot — USDC/stablecoin escrow on Base (read-only values; safe to expose).
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN=base-sepolia            # base-sepolia (testnet) | base (mainnet)
NEXT_PUBLIC_STABLECOIN=USDC               # symbol from lib/crypto/stablecoins.ts (e.g. USDC, EURC)
NEXT_PUBLIC_POT_CONTRACT_ADDRESS=         # deployed PoolEscrow address (empty = test mode)
NEXT_PUBLIC_ENTRY_FEE=10                  # entry fee in stablecoin units
NEXT_PUBLIC_OPERATOR_RAKE=0.1             # operator share, 0–1 (0.1 = 10% = $1 per $10 entry)

# ─────────────────────────────────────────────────────────────────────────────
# Edge Function secrets (set with `supabase secrets set ...`, NOT NEXT_PUBLIC).
# Used by supabase/functions/cache-fixtures to refresh the fixtures cache on a cron
# so a rate-limited free API (e.g. API-Football ~100 req/day) is hit once, not per user.
# ─────────────────────────────────────────────────────────────────────────────
# SPORTS_API_URL=https://www.thesportsdb.com/api/v1/json/3/eventsseason.php?id=4429&s=2026
