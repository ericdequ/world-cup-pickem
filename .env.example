# Supabase — accounts + cloud-synced predictions.
# Create a project at https://supabase.com, then copy these from Project Settings → API.
# The app runs fine without them (falls back to on-device/local play); auth just stays disabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Global tournament pot (USDC escrow on Base). Read-only for transparency; safe to expose.
# Leave the contract empty until the escrow is deployed — the pot panel shows a placeholder.
NEXT_PUBLIC_CHAIN=base-sepolia            # base-sepolia (testnet) | base (mainnet)
NEXT_PUBLIC_POT_CONTRACT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
